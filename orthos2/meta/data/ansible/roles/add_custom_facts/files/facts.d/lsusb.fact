#!/usr/bin/env python3

import json
import shutil
import subprocess
import sys

data = {"noargs": {"stdout": "", "stderr": ""}}

if shutil.which("lsusb"):
    command = ["lsusb"]
    process = subprocess.Popen(
        command, stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True
    )
    data["noargs"]["stdout"] = process.stdout.read()
    data["noargs"]["stderr"] = process.stderr.read()

json_string = json.dumps(data)
sys.stdout.write(json_string)
